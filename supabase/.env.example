# [ATENÇÃO DO DESENVOLVEDOR]
# Copie este arquivo para ".env" na raiz do supabase/ e coloque suas chaves sigilosas

# O Supabase CLI usa esse arquivo para injetar as chaves automaticamente ao rodar as Edge Functions locais:
SUPABASE_URL=https://sua-url-do-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-chave-secreta-service-role
OPENAI_API_KEY=sua-chave-openai-sk-...
STRIPE_WEBHOOK_SECRET=whsec_...
